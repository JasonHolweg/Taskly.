{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "taskly-node",
      "runtimeExecutable": "node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),p=require('path');const root='/Users/jasonholweg/Desktop/Taskly./public';const T={'.html':'text/html','.css':'text/css','.js':'text/javascript','.png':'image/png','.svg':'image/svg+xml','.json':'application/json','.webmanifest':'application/manifest+json'};http.createServer((q,s)=>{let u=q.url.split('?')[0];if(u==='/')u='/index.html';let f=p.join(root,u);fs.readFile(f,(e,d)=>{if(e){s.writeHead(404);s.end('nf')}else{s.writeHead(200,{'Content-Type':T[p.extname(f)]||'text/plain'});s.end(d)}})}).listen(4600,()=>console.log('up on 4600'));"],
      "port": 4600
    }
  ]
}
