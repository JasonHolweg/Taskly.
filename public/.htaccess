# Taskly — public webroot
Options -Indexes
AddDefaultCharset UTF-8
DirectoryIndex index.html

# Schöne Kalender-Abo-URL: /cal/<token>.ics → API
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^cal/([a-f0-9]{32})\.ics$ /api/calendar.php?token=$1 [L,QSA]
</IfModule>

# Dotfiles & interne PHP-Includes sperren
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
<FilesMatch "^_">
  Require all denied
</FilesMatch>

# Statische Assets cachen
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/svg+xml "access plus 30 days"
</IfModule>
